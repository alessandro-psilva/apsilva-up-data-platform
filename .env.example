# Backend address used by scripts and docs
BACKEND_HOST=apsilva-bed-data-platform-api
BACKEND_PORT=8000

# Frontend HTTP port on host
FRONTEND_PORT=8080

# API endpoint consumed by frontend (written into assets/config.js at container startup)
FRONTEND_API_BASE_URL=http://apsilva-bed-data-platform-api:8000

# Azurite service ports on host
AZURITE_BLOB_PORT=10000
AZURITE_QUEUE_PORT=10001
AZURITE_TABLE_PORT=10002

# Local path for Azurite data persistence
AZURITE_DATA_DIR=./azurite-data

# Docker network name used by this stack
PLATFORM_NET_NAME=apsilva-fed-platform-net
