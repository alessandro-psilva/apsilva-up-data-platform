# ============================================================================
# apsilva-up-data-platform/.env.example
# ----------------------------------------------------------------------------
# Modelo de configuracao da orquestracao (script up-data-platform.sh).
# Este arquivo e a fonte principal de parametros para start/stop/restart via repo up.
#
#   cp .env.example .env
# ============================================================================

# ============================================================================
# [BACKEND REFERENCE] - OBRIGATORIO
# ----------------------------------------------------------------------------
# BACKEND_HOST/BACKEND_PORT:
# - Referencia do backend para exibicao, status e composicao de URLs.
# - BACKEND_HOST normalmente e o nome do service docker da API.
BACKEND_HOST=apsilva-bed-data-platform-api
BACKEND_PORT=8000

# ============================================================================
# [FRONTEND REFERENCE] - OBRIGATORIO
# ----------------------------------------------------------------------------
# Porta publica do frontend no host.
FRONTEND_PORT=8080

# FRONTEND_API_BASE_URL:
# - URL da API consumida pelo browser.
# - Deve ser acessivel no host (nao apenas dentro da rede docker).
# - Valor local recomendado usando host alias .localhost.
FRONTEND_API_BASE_URL=http://apsilva-bed-data-platform.localhost:8000

# Alternativa local valida:
# FRONTEND_API_BASE_URL=http://localhost:8000

# ============================================================================
# [AZURITE] - OPCIONAL (com defaults recomendados)
# ----------------------------------------------------------------------------
AZURITE_BLOB_PORT=10000
AZURITE_QUEUE_PORT=10001
AZURITE_TABLE_PORT=10002

# Diretorio de persistencia local dos dados do Azurite.
AZURITE_DATA_DIR=./azurite-data

# ============================================================================
# [DOCKER NETWORK] - OPCIONAL
# ----------------------------------------------------------------------------
# Rede compartilhada entre backend/frontend/orquestracao.
PLATFORM_NET_NAME=apsilva-platform-network
